JWT_SECRET=
JWT_ALGORITHM=HS256

OWUI_BASE_URL=http://localhost:3000
OWUI_VERIFY_TLS=true

MAX_CONCURRENT_SANDBOXES=20
MAX_CONCURRENT_SANDBOXES_PER_USER=1

RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10

CONTAINER_BACKEND=docker
# one image per language; more (e.g. SANDBOX_IMAGE_GO) as tools are added
SANDBOX_IMAGE_PYTHON=python:3.13-trixie
SANDBOX_MAX_MEMORY=500MB
SANDBOX_MAX_CPUS=1
# timeout in seconds, file size in bytes
SANDBOX_EXEC_TIMEOUT=60
SANDBOX_MAX_FILE_SIZE=52428800
