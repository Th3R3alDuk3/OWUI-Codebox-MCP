HOST=0.0.0.0
PORT=8000

# Must equal OpenWebUI's WEBUI_SECRET_KEY (HS256 shared secret).
JWT_SECRET=
JWT_ALGORITHM=HS256
OWUI_BASE_URL=http://localhost:3000

# Per-user sandbox lifecycle (sliding TTL + eviction sweep).
SESSION_TTL_SECONDS=3600
SESSION_SWEEP_INTERVAL_SECONDS=300
MAX_SESSIONS=1000

# llm-sandbox runtime (the container is the isolation boundary).
CONTAINER_BACKEND=docker
SANDBOX_LANG=python
# SANDBOX_IMAGE=        # blank -> llm-sandbox default image for the language
SANDBOX_MAX_MEMORY=1GB
EXEC_TIMEOUT_SECONDS=30
