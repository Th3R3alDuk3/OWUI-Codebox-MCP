HOST=0.0.0.0
PORT=8000

JWT_SECRET=
JWT_ALGORITHM=HS256

OWUI_BASE_URL=http://localhost:3000
OWUI_VERIFY_TLS=true

MAX_CONCURRENT_SANDBOXES=20
MAX_CONCURRENT_SANDBOXES_PER_USER=1

RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10

CONTAINER_BACKEND=docker
SANDBOX_IMAGE=python:3.13-trixie
SANDBOX_MAX_MEMORY=500MB
SANDBOX_MAX_CPUS=1
EXEC_TIMEOUT_SECONDS=60
MAX_FILE_SIZE_BYTES=52428800

PIP_INDEX_URL=https://pypi.org/simple
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=
